{
  "name": "partner-enablement-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for GSI partner enablement - generates reference architectures from Jira project requirements",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postbuild": "cp -r src/knowledge dist/knowledge",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector"
  },
  "keywords": [
    "mcp",
    "anthropic",
    "claude",
    "jira",
    "architecture",
    "partner-enablement"
  ],
  "author": "Ed Gaile",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2",
    "zod": "^3.22.4",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  },
  "exports": {
    ".": "./dist/index.js",
    "./services/knowledgeBase": "./src/services/knowledgeBase.ts",
    "./services/jiraClient": "./src/services/jiraClient.ts",
    "./schemas": "./src/schemas/index.ts",
    "./knowledge/*": "./src/knowledge/*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
