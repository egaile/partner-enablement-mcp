# Jira Cloud Configuration (optional — falls back to mock data if not set)
JIRA_HOST=your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token

# Server Configuration
TRANSPORT=stdio  # "stdio" or "http"
PORT=3000        # HTTP mode port

# Web Demo Configuration
NEXT_PUBLIC_JIRA_CONFIGURED=false  # Set to "true" when real Jira credentials are configured
